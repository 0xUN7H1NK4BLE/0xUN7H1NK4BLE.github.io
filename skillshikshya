        .active-slide { display: block; animation: fadeIn 0.4s ease-out; }
        .hidden-slide { display: none; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

