                            <h4 class="text-emerald-500 font-bold uppercase text-xs">How to get there?</h4>
                            <ul class="space-y-3 text-slate-300">
                                <li class="flex items-start"><span class="text-emerald-500 mr-2">▶</span> <span><strong>Certifications:</strong> CompTIA Security+, CEH, CPTS, OSCP.</span></li>
                                <li class="flex items-start"><span class="text-emerald-500 mr-2">▶</span> <span><strong>Practical Skills:</strong> Play CTFs (HackTheBox, TryHackMe), build a lab.</span></li>
                                <li class="flex items-start"><span class="text-emerald-500 mr-2">▶</span> <span><strong>Portfolio:</strong> Document your hacking or securing journey on GitHub/Blogs.</span></li>
                            </ul>
                        </div>
                        <div class="p-4 bg-emerald-500/10 rounded border border-emerald-500/20 text-center">
                            <p class="text-emerald-400 font-bold">The demand for security talent is infinite. Your journey starts now.</p>
                        </div>
                    </div>
                `
            },
            {
                tag: "Conclusion",
                title: "Next Steps",
                content: `
                    <div class="text-center space-y-8 py-10 max-w-3xl mx-auto">
                        <h3 class="text-4xl font-bold">Module 01 Complete</h3>
                        <p class="text-xl text-slate-400">You now have a foundational understanding of what Cybersecurity is, why it matters, and who the players are.</p>
                        <div class="flex justify-center space-x-4">
                            <button onclick="change(-19)" class="nav-btn">Restart Training</button>
                        </div>
                        <p class="text-sm text-slate-500 pt-10">Presented by Anish Bhattarai <br> CPTS / ASCP / Researcher @ Threatnix</p>
                    </div>
                `
            }
        ];

        let current = 0;

        function render() {
            const wrapper = document.getElementById('slide-wrapper');
            const data = pages[current];
            
            // Re-render the slide
            wrapper.innerHTML = `
                <div class="slide-container active-slide">
                    <span class="mono text-emerald-500 text-xs font-bold uppercase tracking-[0.2em] mb-2 block">${data.tag}</span>
                    <h2 class="text-4xl md:text-6xl font-black text-white tracking-tighter leading-tight mb-8">${data.title}</h2>
                    <div class="content-body">${data.content}</div>
                </div>
            `;

            // Reset scroll to top on slide change
            wrapper.scrollTop = 0;

            // Footer State
            document.getElementById('slide-num').innerText = `${(current + 1).toString().padStart(2, '0')} / ${pages.length}`;
            document.getElementById('prevBtn').disabled = current === 0;
            document.getElementById('nextBtn').innerText = current === pages.length - 1 ? "Finish" : "Next";
            
            // Progress Bar
            const pb = document.getElementById('progress-bar');
            pb.innerHTML = pages.map((_, i) => `<div class="progress-dot ${i <= current ? 'active' : ''}"></div>`).join('');
        }

        function change(dir) {
            current += dir;
            if (current < 0) current = 0;
            if (current >= pages.length) current = pages.length - 1;
            render();
        }

        function quiz(btn, isCorrect) {
            const fb = document.getElementById('fb');
            fb.classList.remove('hidden');
            
            // Reset all options
            document.querySelectorAll('.quiz-option').forEach(b => {
                b.style.borderColor = "transparent";
                b.style.opacity = "0.4";
            });
            
            if (isCorrect) {
                btn.style.borderColor = "#10b981";
                btn.style.opacity = "1";
                fb.innerText = "ACCESS GRANTED: Correct Answer!";
                fb.className = "mt-4 font-bold text-lg p-4 rounded-lg bg-emerald-500/10 text-emerald-500 block";
            } else {
                btn.style.borderColor = "#ef4444";
                btn.style.opacity = "1";
                fb.innerText = "ACCESS DENIED: Try again!";
                fb.className = "mt-4 font-bold text-lg p-4 rounded-lg bg-red-500/10 text-red-500 block";
            }
        }

        // Live Clock
        setInterval(() => {
            document.getElementById('clock').innerText = new Date().toTimeString().split(' ')[0];
        }, 1000);

        // Keyboard navigation
        document.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowRight' || e.key === ' ') change(1);
            if (e.key === 'ArrowLeft') change(-1);
        });

        window.onload = render;
    </script>
</body>
</html>
